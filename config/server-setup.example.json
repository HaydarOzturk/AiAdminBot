      "name": "📋 VERIFICATION",
      "channels": [
        {
          "name": "rules",
          "type": "text",
          "topic": "Read the server rules!",
          "permissions": {
            "everyone": { "deny": ["SendMessages"], "allow": ["ViewChannel"] },
            "Unverified": { "allow": ["ViewChannel"] },
            "New Member": { "allow": ["ViewChannel"] }
          }
        },
        {
          "name": "verification",
          "type": "text",
