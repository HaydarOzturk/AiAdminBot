{
  "roles": [
    {
      "name": "Server Owner",
      "color": "#e74c3c",
      "hoist": true,
      "permissions": ["Administrator"],
      "position": "top"
    },
    {
      "name": "Admin",
      "color": "#e67e22",
      "hoist": true,
      "permissions": ["Administrator"],
      "position": "high"
    },
    {
      "name": "Moderator",
      "color": "#2ecc71",
      "hoist": true,
      "permissions": [
        "ManageMessages",
        "KickMembers",
        "MuteMembers",
        "DeafenMembers",
        "MoveMembers",
        "ManageNicknames",
        "ModerateMembers"
      ],
      "position": "high"
    },
    {
      "name": "New Member",
      "color": "#3498db",
      "hoist": false,
      "permissions": [],
      "position": "low",
      "note": "Verified member role"
    },
    {
      "name": "Unverified",
      "color": "#95a5a6",
      "hoist": false,
      "permissions": [],
      "position": "bottom",
      "note": "Unverified member role"
    }
  ],

  "categories": [
