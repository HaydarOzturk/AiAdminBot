# Discord Bot Configuration
DISCORD_TOKEN=your_bot_token_here

# Database
DATABASE_PATH=./data/bot.db

# Locale: tr, en, de, es, fr, pt, ru, ar
# Affects bot messages AND channel names when using /ai-setup default mode
LOCALE=tr

# Logging
LOG_LEVEL=info

# ── AI Provider (pick ONE) ──────────────────────────────────────────────
# If both are set, Gemini takes priority.

# Option 1: Google Gemini (recommended — free, fast, great at Turkish)
# Get your free key at: https://aistudio.google.com/apikey
#GEMINI_API_KEY=your_gemini_key_here

# Option 2: OpenRouter (free tier, auto-routes to available models)
# Get your free key at: https://openrouter.ai/keys
#OPENROUTER_API_KEY=your_openrouter_key_here

# AI Model override (optional)
# Gemini default: gemini-3.1-flash-lite-preview (15 RPM, 500 RPD — best for bots)
# Other options: gemini-2.5-flash-lite, gemini-2.5-flash, gemini-3-flash
# OpenRouter default: openrouter/free
#AI_MODEL=gemini-3.1-flash-lite-preview

# AI Chat Assistant - users chat with AI in #ai-sohbet channel
AI_CHAT_ENABLED=false
AI_CHAT_CHANNEL=ai-chat
AI_CHAT_RATE_LIMIT=5

# AI Smart Moderation - auto-detect toxic messages
AI_MODERATION_ENABLED=false
AI_MOD_CONFIDENCE_THRESHOLD=0.8
AI_TIMEOUT_MINUTES=3

# Debug: Set your Discord user ID to bypass staff exemption for testing moderation
# This user will be subject to AI moderation even if they have staff roles
#DEBUG_OWNER_ID=210753202000363521

# ── Streaming Detection ────────────────────────────────────────────────
# Detect live streams on Kick, YouTube, Twitch, etc. via /go-live command
#STREAMING_ENABLED=true
# The Discord user ID of the streamer — announcements show their name/avatar
#STREAM_OWNER_ID=123456789012345678
# YouTube Data API key (free from Google Cloud Console — needed for YouTube live checks)
#YOUTUBE_API_KEY=AIza...
# Twitch API credentials (from https://dev.twitch.tv/console — needed for Twitch live checks)
#TWITCH_CLIENT_ID=your_twitch_client_id
#TWITCH_CLIENT_SECRET=your_twitch_client_secret
# Note: Kick live detection uses legacy API (no keys needed)
# Automatic Stream Watcher — auto-detects live streams and announces (no /go-live needed)
# All platforms (Twitch, YouTube, Kick) are polled every N seconds (default 120)
#STREAM_WATCHER_POLL_INTERVAL_SECONDS=120
# How long to wait (seconds) before announcing — confirms the stream is stable
#STREAM_WATCHER_CONFIRMATION_DELAY_SECONDS=60
# YouTube-specific poll interval (longer to conserve API quota; default 600 = 10 minutes)
#STREAM_WATCHER_YT_POLL_INTERVAL_SECONDS=600
# Max YouTube search.list API calls per day (each costs 100 quota units; default 100)
# YouTube is only checked when live on Twitch/Kick, so real usage is much lower
#YOUTUBE_DAILY_QUOTA_LIMIT=100

# ── Link Filter ────────────────────────────────────────────────────────
# Block links/URLs in chat (staff with Manage Messages are exempt)
#LINK_FILTER_ENABLED=false
#LINK_FILTER_WARN_USER=true

# ── AFK Channel ────────────────────────────────────────────────────────
# Discord's native AFK handles inactivity by default.
# Enable custom tracking only if you want the bot to do extra idle detection.
#AFK_CUSTOM_ENABLED=false
#AFK_TIMEOUT_MINUTES=30

# ── Web Dashboard (v1.3) ──────────────────────────────────────────────
# Set WEB_PORT to enable the admin dashboard (disabled by default)
# Access at http://your-server-ip:3000
#WEB_PORT=3000
#WEB_PASSWORD=your_secure_password_here

# Discord OAuth2 (optional — enables "Login with Discord" on dashboard)
# Only server owners can access their guild's data when using OAuth
# Get your client secret from: Discord Developer Portal → Your App → OAuth2
#WEB_OAUTH_CLIENT_SECRET=your_oauth_client_secret
#WEB_OAUTH_REDIRECT_URI=https://your-domain.com/api/auth/callback
