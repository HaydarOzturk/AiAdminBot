# Discord Bot Configuration
DISCORD_TOKEN=your_bot_token_here

# Database
DATABASE_PATH=./data/bot.db

# Locale: tr, en, de, es, fr, pt, ru, ar
# Affects bot messages AND channel names when using /ai-setup default mode
LOCALE=tr

# Logging
LOG_LEVEL=info

# AI Features (OpenRouter - Free Models)
# Get your free API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# AI Model (default: auto-selects best free model)
# Browse free models at: https://openrouter.ai/models?q=free
#AI_MODEL=openrouter/free

# AI Chat Assistant - users chat with AI in #ai-sohbet channel
AI_CHAT_ENABLED=false
AI_CHAT_CHANNEL=ai-chat
AI_CHAT_RATE_LIMIT=5

# AI Smart Moderation - auto-detect toxic messages
AI_MODERATION_ENABLED=false
AI_MOD_CONFIDENCE_THRESHOLD=0.8
