# Discord Bot Configuration
DISCORD_TOKEN=your_bot_token_here

# Database
DATABASE_PATH=./data/bot.db

# Locale: tr, en, de, es, fr, pt, ru, ar
# Affects bot messages AND channel names when using /ai-setup default mode
LOCALE=tr

# Logging
LOG_LEVEL=info

# ── AI Provider (pick ONE) ──────────────────────────────────────────────
# If both are set, Gemini takes priority.

# Option 1: Google Gemini (recommended — free, fast, great at Turkish)
# Get your free key at: https://aistudio.google.com/apikey
#GEMINI_API_KEY=your_gemini_key_here

# Option 2: OpenRouter (free tier, auto-routes to available models)
# Get your free key at: https://openrouter.ai/keys
#OPENROUTER_API_KEY=your_openrouter_key_here

# AI Model override (optional)
# Gemini default: gemini-3.1-flash-lite-preview (15 RPM, 500 RPD — best for bots)
# Other options: gemini-2.5-flash-lite, gemini-2.5-flash, gemini-3-flash
# OpenRouter default: openrouter/free
#AI_MODEL=gemini-3.1-flash-lite-preview

# AI Chat Assistant - users chat with AI in #ai-sohbet channel
AI_CHAT_ENABLED=false
AI_CHAT_CHANNEL=ai-chat
AI_CHAT_RATE_LIMIT=5

# AI Smart Moderation - auto-detect toxic messages
AI_MODERATION_ENABLED=false
AI_MOD_CONFIDENCE_THRESHOLD=0.8
AI_TIMEOUT_MINUTES=3

# Debug: Set your Discord user ID to bypass staff exemption for testing moderation
# This user will be subject to AI moderation even if they have staff roles
#DEBUG_OWNER_ID=210753202000363521

# ── Link Filter ────────────────────────────────────────────────────────
# Block links/URLs in chat (staff with Manage Messages are exempt)
#LINK_FILTER_ENABLED=false
#LINK_FILTER_WARN_USER=true

# ── AFK Channel ────────────────────────────────────────────────────────
# Discord's native AFK handles inactivity by default.
# Enable custom tracking only if you want the bot to do extra idle detection.
#AFK_CUSTOM_ENABLED=false
#AFK_TIMEOUT_MINUTES=30

# ── Web Dashboard (v1.3) ──────────────────────────────────────────────
# Set WEB_PORT to enable the admin dashboard (disabled by default)
# Access at http://your-server-ip:3000
#WEB_PORT=3000
#WEB_PASSWORD=your_secure_password_here
