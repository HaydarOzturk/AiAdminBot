{
  "name": "aiadminbot",
  "version": "1.4.0",
  "description": "AI-powered Discord server administration bot with verification, moderation, roles, logging, leveling, and server setup automation.",
  "main": "src/index.js",
  "bin": "src/exe-entry.js",
  "scripts": {
    "start": "node src/index.js",
    "setup": "node src/setup-wizard.js",
    "deploy": "node src/deploy-commands.js",
    "dev": "node --watch src/index.js",
    "lint": "eslint src/",
    "test": "node --test tests/",
    "build": "node scripts/build.js win",
    "build:win": "node scripts/build.js win",
    "build:mac": "node scripts/build.js mac",
    "build:linux": "node scripts/build.js linux",
    "build:all": "node scripts/build.js all"
  },
  "pkg": {
    "scripts": [
      "src/commands/**/*.js",
      "src/events/**/*.js",
      "src/systems/**/*.js",
      "src/handlers/**/*.js",
      "src/utils/**/*.js",
      "src/web/**/*.js",
      "node_modules/express/**/*.js",
      "node_modules/body-parser/**/*.js",
      "node_modules/raw-body/**/*.js",
      "node_modules/content-disposition/**/*.js",
      "node_modules/cookie/**/*.js",
      "node_modules/cookie-signature/**/*.js",
      "node_modules/debug/**/*.js",
      "node_modules/depd/**/*.js",
      "node_modules/destroy/**/*.js",
      "node_modules/encodeurl/**/*.js",
      "node_modules/escape-html/**/*.js",
      "node_modules/etag/**/*.js",
      "node_modules/finalhandler/**/*.js",
      "node_modules/fresh/**/*.js",
      "node_modules/merge-descriptors/**/*.js",
      "node_modules/methods/**/*.js",
      "node_modules/mime/**/*.js",
      "node_modules/ms/**/*.js",
      "node_modules/on-finished/**/*.js",
      "node_modules/parseurl/**/*.js",
      "node_modules/path-to-regexp/**/*.js",
      "node_modules/proxy-addr/**/*.js",
      "node_modules/qs/**/*.js",
      "node_modules/range-parser/**/*.js",
      "node_modules/safe-buffer/**/*.js",
      "node_modules/safer-buffer/**/*.js",
      "node_modules/send/**/*.js",
      "node_modules/serve-static/**/*.js",
      "node_modules/setprototypeof/**/*.js",
      "node_modules/statuses/**/*.js",
      "node_modules/type-is/**/*.js",
      "node_modules/unpipe/**/*.js",
      "node_modules/utils-merge/**/*.js",
      "node_modules/vary/**/*.js"
    ],
    "assets": [
      "locales/**/*.json",
      "config/*.example.json",
      ".env.example",
      "node_modules/sql.js/dist/sql-wasm.wasm",
      "node_modules/express/package.json",
      "node_modules/body-parser/package.json",
      "node_modules/mime/types.json",
      "node_modules/mime/package.json",
      "src/web/public/**/*"
    ],
    "targets": [
      "node20-win-x64"
    ],
    "outputPath": "dist"
  },
  "keywords": [
    "discord",
    "bot",
    "admin",
    "moderation",
    "ai",
    "openrouter"
  ],
  "author": "HaydarOzturk",
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.16.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
