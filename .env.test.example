# ============================================================
#  AiAdminBot — TEST ENVIRONMENT
#  Copy this to .env when running in test mode.
#  NEVER use your production bot token here!
# ============================================================

# TEST bot token (create a separate bot at https://discord.com/developers/applications)
DISCORD_TOKEN=your_test_bot_token_here

# Separate database so production data is not affected
DATABASE_PATH=./data/test-bot.db

# Different web port to avoid conflicts with production
WEB_PORT=3001
WEB_PASSWORD=testpassword

# AI keys (safe to reuse from production — read-only APIs)
GEMINI_API_KEY=your_gemini_key
#OPENROUTER_API_KEY=your_openrouter_key

# Enable features for testing
AI_CHAT_ENABLED=true
AI_MODERATION_ENABLED=true
AI_MOD_CONFIDENCE_THRESHOLD=0.8
AI_TIMEOUT_MINUTES=1

# Disable features that might cause issues in test
STREAMING_ENABLED=false
LINK_FILTER_ENABLED=false
AFK_CUSTOM_ENABLED=false

# Set yourself as debug owner to test moderation on yourself
DEBUG_OWNER_ID=your_discord_user_id

# Language
LOCALE=en
